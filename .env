# Variables globals (pots compartir les credencials amb Docker Compose i les aplicacions)

# MongoDB
MONGO_USER=root
MONGO_PASSWORD=password
MONGO_URI=mongodb://root:password@mongo:27017/ecommerce?authSource=admin

# Backend
PORT=3000
JWT_SECRET=super-secret-key
JWT_REFRESH_SECRET=super-refresh-secret-key

# Stripe (Configura-les aquí si vols o deixa-les al .env del backend)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000/api

# Observabilitat
NODE_ENV=development
LOG_LEVEL=debug
